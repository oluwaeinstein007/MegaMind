# ═══════════════════════════════════════════════════════════════
#  MegaMind Social Agent — environment variables
# ═══════════════════════════════════════════════════════════════

# ── Gemini (required) ──────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key
# Model to use — gemini-2.0-flash (default) or gemini-1.5-pro
GEMINI_MODEL=gemini-2.0-flash

# ── MegaMind ──────────────────────────────────────────────────
# Path to MegaMind's SQLite database (absolute or relative)
MEGAMIND_DB_PATH=../dist/ingestor.db

# ── Qdrant semantic search (optional — falls back to SQLite LIKE) ──
QDRANT_HOST=http://localhost:6333
QDRANT_KEY=your_qdrant_api_key
QDRANT_COLLECTION_NAME=megamind
QDRANT_ENABLED=true
# Must match the embedding model used when ingesting: openai | gemini
EMBEDDING_PROVIDER=openai
EMBEDDING_VECTOR_SIZE=1536

# ── OpenAI (only needed for Qdrant semantic search with openai embeddings) ──
OPENAI_API_KEY=your_openai_api_key

# ── Image generation (optional) ────────────────────────────────
# Leave empty to use free Pollinations.ai fallback
STABILITY_AI_API_KEY=

# ── Twitter / X ───────────────────────────────────────────────
TWITTER_APP_KEY=
TWITTER_APP_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=
# Handle to monitor for replies (e.g. @mytravelbot)
TWITTER_MONITOR_HANDLE=

# ── Telegram ──────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_DEFAULT_CHAT_ID=

# ── Discord ───────────────────────────────────────────────────
DISCORD_BOT_TOKEN=
DISCORD_DEFAULT_CHANNEL_ID=

# ── Slack ─────────────────────────────────────────────────────
SLACK_BOT_TOKEN=
SLACK_DEFAULT_CHANNEL=general

# ── WhatsApp Business Cloud API ───────────────────────────────
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# ── Facebook Graph API ────────────────────────────────────────
FACEBOOK_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=

# ── Instagram Graph API ───────────────────────────────────────
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_ACCOUNT_ID=

# ── LinkedIn ──────────────────────────────────────────────────
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_USER_ID=

# ── Webhook server (improvement #2) ───────────────────────────
WEBHOOK_PORT=3456
# Secret token added by platforms when calling your webhook
WEBHOOK_SECRET=your_webhook_secret
# Set to 'true' to enable the webhook server on startup
WEBHOOK_ENABLED=false

# ── Scheduler (improvement #1) ────────────────────────────────
# Cron expression for auto travel posts (default: 9am daily)
SCHEDULER_CRON=0 9 * * *
# Comma-separated list of platforms to broadcast to on schedule
SCHEDULER_PLATFORMS=twitter
# Set to 'true' to enable the scheduler on startup
SCHEDULER_ENABLED=false

# ── TVA OTA booking tools (flight, hotel, visa, immigration, account) ──
# Powered by the sibling TravelAgentMCP repo's mcps/* servers, spawned over
# stdio per conversation. Set to 'false' to disable booking tools entirely
# and run NomadSage as a knowledge-base-only advisor.
TVA_MCP_ENABLED=true

# TVA OTA API base URL — forwarded to every spawned mcps/* child process.
TVA_BASE_URL=http://localhost:8000

# Path overrides for each domain server's built entry point. Defaults assume
# TravelAgentMCP is checked out as a sibling of MegaMind (../../TravelAgentMCP
# relative to this package) — override these for Docker or other layouts.
TVA_FLIGHT_MCP_PATH=
TVA_HOTEL_MCP_PATH=
TVA_VISA_MCP_PATH=
TVA_IMMIGRATION_MCP_PATH=
TVA_ACCOUNT_MCP_PATH=

# Visa/immigration content API (country requirements, fees, FAQs) — a
# separate service from the TVA OTA backend above.
VISA_CONTENT_API_BASE_URL=
VISA_CONTENT_API_KEY=
IMMIGRATION_CONTENT_API_BASE_URL=
IMMIGRATION_CONTENT_API_KEY=
