{
  "name": "megamind-social-agent",
  "version": "3.0.0",
  "description": "Gemini-powered social media agent — posts, replies, travel content, scheduling, and webhooks via social-mcp",
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "main": "dist/index.js",
  "bin": {
    "megamind-agent": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "dev:watch": "tsx watch src/index.ts",
    "dev:verbose": "tsx src/index.ts --verbose"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@qdrant/js-client-rest": "^1.15.0",
    "better-sqlite3": "^12.5.0",
    "dotenv": "^17.3.1",
    "express": "^4.21.0",
    "node-cron": "^3.0.3",
    "openai": "^4.104.0",
    "social-mcp": "^1.3.1",
    "twitter-api-v2": "^1.29.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^4.17.21",
    "@types/node": "^24.7.0",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
