# ── Claude / Anthropic ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key

# ── MegaMind ─────────────────────────────────────────────────────────────────
# Path to MegaMind's SQLite database (relative or absolute)
# Default: ../dist/ingestor.db  (the compiled MegaMind server DB)
MEGAMIND_DB_PATH=../dist/ingestor.db

# ── Twitter / X ───────────────────────────────────────────────────────────────
TWITTER_APP_KEY=
TWITTER_APP_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
# Default chat/channel ID the agent posts to when none is specified
TELEGRAM_DEFAULT_CHAT_ID=

# ── Discord ───────────────────────────────────────────────────────────────────
DISCORD_BOT_TOKEN=
# Default channel ID the agent posts to when none is specified
DISCORD_DEFAULT_CHANNEL_ID=

# ── Slack ─────────────────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=
# Default channel (name or ID) the agent posts to when none is specified
SLACK_DEFAULT_CHANNEL=general

# ── WhatsApp Business Cloud API ───────────────────────────────────────────────
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# ── Facebook Graph API ────────────────────────────────────────────────────────
FACEBOOK_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=

# ── Instagram Graph API ───────────────────────────────────────────────────────
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_ACCOUNT_ID=
