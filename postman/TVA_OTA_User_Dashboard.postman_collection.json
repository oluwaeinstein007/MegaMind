              "host": ["{{base_url}}"], "path": ["api","v1","hotels","amadeus","bookings","{{hotelBookingId}}"],
              "query": [
                { "key": "user_uuid", "value": "{{user_uuid}}", "disabled": true }
              ]
            }
          }
        }
      ]
    },

