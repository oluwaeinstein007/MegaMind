{
  "info": {
    "_postman_id": "tva-ota-user-dashboard-v1",
    "name": "TVA OTA – User Dashboard API",
    "description": "All client-facing endpoints for the TVA OTA user portal.\n\n**Base URL:** `{{base_url}}/api/v1`\n\n**Authentication:** All endpoints in this collection (except Auth) require a Bearer token.\nLogin via `POST /user/login` and set the response token in the `token` collection variable.\n\n---\n\n## Flow\n1. **Register / Login** → get `token`\n2. **Profile** → view/edit user info\n3. **Flight Bookings** → list, view detail, cancel, resend ticket\n4. **Hotel Bookings** → list, view detail\n5. **Visa** → bookings, updates, followup questions\n6. **Immigration** → bookings, updates, notifications\n7. **Notifications** → get all, mark as read",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url",        "value": "http://localhost:8000", "type": "string" },
    { "key": "token",           "value": "",                      "type": "string", "description": "Set after login" },
    { "key": "user_uuid",       "value": "",                      "type": "string", "description": "Set after login – used for optional-auth booking lookups" },
    { "key": "tvaId",           "value": "",                      "type": "string", "description": "TVA booking ID from flight book response" },
    { "key": "cancelUuid",      "value": "",                      "type": "string", "description": "cancel_uuid from flight book response" },
    { "key": "flightBookingId", "value": "",                      "type": "string", "description": "Local DB id of flight booking" },
    { "key": "hotelBookingId",  "value": "",                      "type": "string", "description": "Local DB id of hotel booking" },
    { "key": "visaBookingId",   "value": "",                      "type": "string", "description": "Local DB id of visa booking" },
    { "key": "notificationId",  "value": "",                      "type": "string", "description": "Notification ID for mark-as-read" }
  ],
  "item": [

    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"first_name\": \"John\",\n  \"last_name\": \"Doe\",\n  \"email\": \"john.doe@example.com\",\n  \"password\": \"Password123!\",\n  \"password_confirmation\": \"Password123!\",\n  \"phone_number\": \"+2348012345678\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/user/register",
              "host": ["{{base_url}}"], "path": ["api","v1","user","register"]
            }
          }
        },
        {
          "name": "Login",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "var r = pm.response.json();",
                "if (r.token) {",
                "  pm.collectionVariables.set('token', r.token);",
                "  pm.collectionVariables.set('user_uuid', r.data && r.data.user_uuid ? r.data.user_uuid : '');",
                "  console.log('Logged in. UUID:', r.data && r.data.user_uuid);",
                "}"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john.doe@example.com\",\n  \"password\": \"Password123!\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/user/login",
              "host": ["{{base_url}}"], "path": ["api","v1","user","login"]
            }
          }
        },
        {
          "name": "Forgot Password (Send OTP)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"john.doe@example.com\"\n}" },
            "url": {
              "raw": "{{base_url}}/api/v1/user/forgot-password",
              "host": ["{{base_url}}"], "path": ["api","v1","user","forgot-password"]
            }
          }
        },
        {
          "name": "Verify OTP",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"john.doe@example.com\",\n  \"otp\": \"123456\"\n}" },
            "url": {
              "raw": "{{base_url}}/api/v1/user/verify-otp",
              "host": ["{{base_url}}"], "path": ["api","v1","user","verify-otp"]
            }
          }
        },
        {
          "name": "Resend OTP",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"john.doe@example.com\"\n}" },
            "url": {
              "raw": "{{base_url}}/api/v1/user/resend-otp",
              "host": ["{{base_url}}"], "path": ["api","v1","user","resend-otp"]
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/user/logout",
              "host": ["{{base_url}}"], "path": ["api","v1","user","logout"]
            }
          }
        }
      ]
    },

