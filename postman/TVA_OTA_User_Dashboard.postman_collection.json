              "query": [
                { "key": "per_page",  "value": "15" },
                { "key": "user_uuid", "value": "{{user_uuid}}", "disabled": true, "description": "Use instead of token for guest lookup" },
                { "key": "status",    "value": "", "disabled": true, "description": "pending | confirmed | failed | cancelled" }
