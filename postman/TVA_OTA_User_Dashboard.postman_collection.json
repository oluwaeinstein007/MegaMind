    {
      "name": "Flight Bookings",
      "item": [
        {
          "name": "List My Flight Bookings",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/flights/bookings?per_page=15",
              "host": ["{{base_url}}"], "path": ["api","v1","flights","bookings"],
              "query": [
                { "key": "per_page",    "value": "15" },
                { "key": "user_uuid",   "value": "{{user_uuid}}", "disabled": true, "description": "Use instead of token for guest lookup" },
                { "key": "status",      "value": "", "disabled": true, "description": "pending | confirmed | failed | cancelled" },
                { "key": "origin",      "value": "", "disabled": true, "description": "IATA code e.g. LOS" },
                { "key": "destination", "value": "", "disabled": true, "description": "IATA code e.g. LHR" },
                { "key": "trip_type",   "value": "", "disabled": true, "description": "one-way | round-trip | multi-city" }
              ]
            },
            "description": "Returns paginated list of the authenticated user's flight bookings.\n\nSupports filter query params: `status`, `origin`, `destination`, `trip_type`."
          }
        },
        {
          "name": "Get Flight Booking Detail (full itinerary)",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/flights/bookings/{{flightBookingId}}",
              "host": ["{{base_url}}"], "path": ["api","v1","flights","bookings","{{flightBookingId}}"],
              "query": [
                { "key": "user_uuid", "value": "{{user_uuid}}", "disabled": true, "description": "Use instead of token for guest lookup" }
              ]
            },
            "description": "Returns booking with full `itinerary` block (segments, airline logos, cabin, baggage, departure/arrival times) and `pnr`."
          }
        },
        {
          "name": "Verify Booking by TVA ID (QR scan)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/flights/verify/{{tvaId}}",
              "host": ["{{base_url}}"], "path": ["api","v1","flights","verify","{{tvaId}}"]
            },
            "description": "Public — no auth needed. Looks up a booking by TVA ID for QR code scans or confirmation page display."
          }
        },
        {
          "name": "Cancel My Booking",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/flights/cancel/{{cancelUuid}}",
              "host": ["{{base_url}}"], "path": ["api","v1","flights","cancel","{{cancelUuid}}"]
            },
            "description": "User-facing cancel using `cancel_uuid` from the booking response or receipt email manage link. No auth token needed — the UUID is the secret.\n\nCancels on Amadeus and marks the local record as `status=cancelled`. Sets `payment_status=refunded` if already paid, or `failed` if still pending."
          }
        },
        {
          "name": "Resend E-Ticket Email",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/flights/resend-ticket/{{tvaId}}",
              "host": ["{{base_url}}"], "path": ["api","v1","flights","resend-ticket","{{tvaId}}"]
            },
            "description": "Resends the flight receipt / e-ticket email to the traveler's email on record.\n\nUse when the traveler didn't receive the confirmation email after booking."
          }
        }
      ]
    },

    {
      "name": "Hotel Bookings",
