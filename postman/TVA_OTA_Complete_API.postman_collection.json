      "item": [
        {
          "name": "User Auth",
          "item": [
            {"name":"Register","request":{"auth":{"type":"noauth"},"method":"POST","header":[],"url":{"raw":"{{base_url}}/api/v1/user/register","host":["{{base_url}}"],"path":["api","v1","user","register"]},"body":{"mode":"raw","raw":"{\"name\":\"John Doe\",\"email\":\"john@example.com\",\"password\":\"password\",\"password_confirmation\":\"password\",\"phone\":\"+2348012345678\"}","options":{"raw":{"language":"json"}}}}},
            {"name":"Login","request":{"auth":{"type":"noauth"},"method":"POST","header":[],"url":{"raw":"{{base_url}}/api/v1/user/login","host":["{{base_url}}"],"path":["api","v1","user","login"]},"body":{"mode":"raw","raw":"{\"email\":\"john@example.com\",\"password\":\"password\"}","options":{"raw":{"language":"json"}}}},"event":[{"listen":"test","script":{"exec":["if (pm.response.code === 200) {","  var r = pm.response.json();","  pm.collectionVariables.set('token', r.data?.token || r.token || '');","  pm.collectionVariables.set('user_uuid', r.data?.user?.user_uuid || r.data?.user_uuid || '');","}"],"type":"text/javascript"}}]},
            {"name":"Social Auth","request":{"auth":{"type":"noauth"},"method":"POST","header":[],"url":{"raw":"{{base_url}}/api/v1/user/social-auth","host":["{{base_url}}"],"path":["api","v1","user","social-auth"]},"body":{"mode":"raw","raw":"{\"provider\":\"google\",\"token\":\"GOOGLE_ACCESS_TOKEN\"}","options":{"raw":{"language":"json"}}}}},
            {"name":"Forgot Password","request":{"auth":{"type":"noauth"},"method":"POST","header":[],"url":{"raw":"{{base_url}}/api/v1/user/forgot-password","host":["{{base_url}}"],"path":["api","v1","user","forgot-password"]},"body":{"mode":"raw","raw":"{\"email\":\"john@example.com\"}","options":{"raw":{"language":"json"}}}}},
            {"name":"Resend OTP","request":{"auth":{"type":"noauth"},"method":"POST","header":[],"url":{"raw":"{{base_url}}/api/v1/user/resend-otp","host":["{{base_url}}"],"path":["api","v1","user","resend-otp"]},"body":{"mode":"raw","raw":"{\"email\":\"john@example.com\"}","options":{"raw":{"language":"json"}}}}},
            {"name":"Verify OTP","request":{"auth":{"type":"noauth"},"method":"POST","header":[],"url":{"raw":"{{base_url}}/api/v1/user/verify-otp","host":["{{base_url}}"],"path":["api","v1","user","verify-otp"]},"body":{"mode":"raw","raw":"{\"email\":\"john@example.com\",\"otp\":\"123456\",\"password\":\"newpassword\",\"password_confirmation\":\"newpassword\"}","options":{"raw":{"language":"json"}}}}},
            {"name":"Logout","request":{"auth":{"type":"bearer","bearer":[{"key":"token","value":"{{token}}","type":"string"}]},"method":"POST","header":[],"url":{"raw":"{{base_url}}/api/v1/user/logout","host":["{{base_url}}"],"path":["api","v1","user","logout"]}}}
