# MegaMind — environment variables
# Copy to `.env` and fill in real values. Never commit `.env` to version control.

# ── LLM / Embedding Provider ─────────────────────────────────────────────────
# Choose one: openai | gemini | voyage  (anthropic is accepted as alias for voyage)
LLM_PROVIDER=gemini

# ── OpenAI (LLM_PROVIDER=openai) ─────────────────────────────────────────────
# Models: text-embedding-3-small (1536), text-embedding-3-large (3072), text-embedding-ada-002 (1536)
# LLM_PROVIDER=openai
# LLM_API_KEY=sk-...
# OPENAI_API_KEY=sk-...           # alternative to LLM_API_KEY
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── Google Gemini (LLM_PROVIDER=gemini) ──────────────────────────────────────
# Models: gemini-embedding-001 (3072), text-embedding-004 (768)
# Get an API key at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=                   # primary key — checked first
LLM_API_KEY=                      # fallback (also accepted for Gemini)
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# ── Voyage AI / Anthropic (LLM_PROVIDER=voyage or anthropic) ─────────────────
# Voyage AI is Anthropic's recommended embedding provider for RAG with Claude.
# Models: voyage-3-large (1024), voyage-3 (1024), voyage-3-lite (512),
#         voyage-code-3 (1024), voyage-finance-2 (1024), voyage-law-2 (1024)
# Get an API key at: https://www.voyageai.com
# LLM_PROVIDER=voyage
# VOYAGE_API_KEY=pa-...
# ANTHROPIC_API_KEY=...           # alternative to VOYAGE_API_KEY
# VOYAGE_EMBEDDING_MODEL=voyage-3

# ── Embedding ─────────────────────────────────────────────────────────────────
# Must match your model's output dimension (see model notes above)
EMBEDDING_VECTOR_SIZE=3072
# Chunks sent per embedding API call — raise if your plan allows larger batches
EMBEDDING_BATCH_SIZE=50

# ── Qdrant ────────────────────────────────────────────────────────────────────
QDRANT_HOST=https://your-cluster.cloud.qdrant.io
QDRANT_KEY=
QDRANT_COLLECTION_NAME=megamind   # created automatically on first run
QDRANT_ENABLED=true               # set false to use SQLite only (no vector search)
